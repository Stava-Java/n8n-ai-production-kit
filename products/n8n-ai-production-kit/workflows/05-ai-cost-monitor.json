            {
              "id": "set-slack-channel",
              "name": "slack_channel_id",
              "value": "REPLACE_WITH_SLACK_CHANNEL_ID",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000020",
      "name": "Cost Monitor Settings",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-1100, 0],
      "notes": "EDIT ME: your daily spend alert threshold (USD) and Slack channel ID."
    },
    {
      "parameters": {
        "content": "## 🛠 Setup (5 minutes)\n1. Open **Cost Monitor Settings**: set your daily alert threshold and Slack channel ID.\n2. Click **Fetch OpenAI Costs** → add a Header Auth credential: name `Authorization`, value `Bearer <your admin key>` (the word Bearer, a space, then the key).\n3. Click **Fetch Anthropic Costs** → add a Header Auth credential: name `x-api-key`, value your Anthropic admin key.\n4. Open **Check Idempotency Ledger** and pick your imported *PK-04 Idempotency Ledger* workflow.\n5. Connect Slack on the two alert nodes, then publish.\n\n⚠️ Provider note: these endpoints need **admin/organization** keys - regular API keys get a 401. Only track providers you use; you can delete the other branch.",
        "height": 360,
        "width": 400
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000021",
      "name": "Setup Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [-1320, -420]
    },
    {
      "parameters": {
        "url": "=https://api.openai.com/v1/organization/costs?start_time={{ Math.floor(Date.now() / 1000) - 86400 }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "timeout": 20000
        }
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000005",
      "name": "Fetch OpenAI Costs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-660, -100],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "onError": "continueErrorOutput",
      "notes": "Requires an OpenAI ADMIN key in a Header Auth credential (Authorization: Bearer <admin key>). See INSTALL.md. Endpoint shape tested in COMPATIBILITY.md."
    },
    {
      "parameters": {
        "url": "=https://api.anthropic.com/v1/organizations/cost_report?starting_at={{ $now.minus({ days: 1 }).toFormat('yyyy-MM-dd') }}T00:00:00Z",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            }
          ]
        },
        "options": {
          "timeout": 20000
        }
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000006",
      "name": "Fetch Anthropic Costs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-660, 100],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "onError": "continueErrorOutput",
      "notes": "Requires an Anthropic ADMIN key in a Header Auth credential (x-api-key: <admin key>). See INSTALL.md. Endpoint shape tested in COMPATIBILITY.md."
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "={{ $('Cost Monitor Settings').first().json.slack_channel_id }}",
          "mode": "id"
        },
        "text": "=:warning: AI cost monitor could not fetch provider usage\n*Source node:* {{ $prevNode.name }}\n*Error:* {{ $json.error ? String($json.error.message || JSON.stringify($json.error)).slice(0, 300) : 'unknown error' }}\nThe other provider (if configured) still runs. Check credentials and COMPATIBILITY.md.",
        "otherOptions": {}
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000007",
      "name": "Alert Provider Fetch Failure",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [-440, 260],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 2000,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Tag the raw response so the normalizer knows which provider it came from.\nreturn $input.all().map((item) => ({\n  json: { provider: 'openai', body: item.json },\n}));"
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000008",
      "name": "Tag OpenAI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-440, -100]
    },
    {
      "parameters": {
        "jsCode": "// Tag the raw response so the normalizer knows which provider it came from.\nreturn $input.all().map((item) => ({\n  json: { provider: 'anthropic', body: item.json },\n}));"
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000009",
      "name": "Tag Anthropic Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-440, 100]
    },
    {
      "parameters": {
        "mode": "append"
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000010",
      "name": "Combine Provider Responses",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [-220, 0]
    },
    {
      "parameters": {
        "jsCode": "// Normalize provider cost responses into one record per provider per day.\n// Parsing is defensive on purpose: provider response shapes drift. When a\n// shape is unrecognized we record a parse_error instead of failing silently.\nconst records = [];\nconst usageDate = new Date(Date.now() - 86400000).toISOString().slice(0, 10);\n\nfunction sumOpenAi(body) {\n  let total = 0;\n  let found = false;\n  for (const bucket of (body && body.data) || []) {\n    for (const r of (bucket && bucket.results) || []) {\n      const v = Number(r && r.amount && r.amount.value);\n      if (Number.isFinite(v)) {\n        total += v;\n        found = true;\n      }\n    }\n  }\n  return found ? total : null;\n}\n\nfunction sumAnthropic(body) {\n  let total = 0;\n  let found = false;\n  for (const bucket of (body && body.data) || []) {\n    for (const r of (bucket && bucket.results) || []) {\n      let v = Number(r && r.amount);\n      if (!Number.isFinite(v)) v = Number(r && r.cost && r.cost.amount);\n      if (Number.isFinite(v)) {\n        total += v;\n        found = true;\n      }\n    }\n  }\n  return found ? total : null;\n}\n\nfor (const item of $input.all()) {\n  const provider = item.json.provider || 'unknown';\n  const body = item.json.body || {};\n  let cost = null;\n  let parseError = '';\n  try {\n    if (provider === 'openai') cost = sumOpenAi(body);\n    else if (provider === 'anthropic') cost = sumAnthropic(body);\n    if (cost === null) {\n      parseError =\n        'No cost values found in response. The provider API shape may have drifted - compare with COMPATIBILITY.md.';\n    }\n  } catch (e) {\n    parseError = String(e.message).slice(0, 300);\n  }\n  records.push({\n    json: {\n      provider,\n      usage_date: usageDate,\n      estimated_cost_usd: cost === null ? '' : Math.round(cost * 10000) / 10000,\n      parse_error: parseError,\n      event_key: 'aicost::' + provider + '::' + usageDate,\n      recorded_at: new Date().toISOString(),\n    },\n  });\n}\nreturn records;"
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000011",
      "name": "Normalize And Price Usage",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [0, 0]
    },

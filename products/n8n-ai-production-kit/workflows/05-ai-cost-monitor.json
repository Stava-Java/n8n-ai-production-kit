          "value": "ai_cost_log",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "provider": "={{ $('Normalize And Price Usage').item.json.provider }}",
            "usage_date": "={{ $('Normalize And Price Usage').item.json.usage_date }}",
            "estimated_cost_usd": "={{ $('Normalize And Price Usage').item.json.estimated_cost_usd || 0 }}",
            "parse_error": "={{ $('Normalize And Price Usage').item.json.parse_error }}",
            "event_key": "={{ $('Normalize And Price Usage').item.json.event_key }}",
            "recorded_at": "={{ $('Normalize And Price Usage').item.json.recorded_at }}"
          },
          "schema": []
        },
        "options": {}
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000015",
      "name": "Insert Cost Record",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [660, 140],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "jsCode": "// Compare each provider's daily spend against the alert threshold.\nconst threshold = Number($('Cost Monitor Settings').first().json.daily_spend_alert_usd || 25);\nreturn $input.all().map((item) => {\n  const cost = Number(item.json.estimated_cost_usd);\n  return {\n    json: {\n      provider: item.json.provider,\n      usage_date: item.json.usage_date,\n      estimated_cost_usd: item.json.estimated_cost_usd,\n      parse_error: item.json.parse_error || '',\n      alert_threshold_usd: threshold,\n      over_threshold: Number.isFinite(cost) && cost > threshold,\n    },\n  };\n});"
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000016",
      "name": "Evaluate Spend Threshold",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 140]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "id": "over-threshold",
              "leftValue": "={{ $json.over_threshold }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000017",
      "name": "Over Threshold?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1100, 140]
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "={{ $('Cost Monitor Settings').first().json.slack_channel_id }}",
          "mode": "id"
        },
        "text": "=:moneybag: AI spend over threshold\n*Provider:* {{ $json.provider }}\n*Date:* {{ $json.usage_date }}\n*Spend:* ${{ $json.estimated_cost_usd }} (threshold ${{ $json.alert_threshold_usd }})\nReview the ai_cost_log Data Table and the client workflows driving this spend.",
        "otherOptions": {}
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000018",
      "name": "Send Spend Alert",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [1320, 40],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {},
      "id": "9f1a2b30-0005-4c05-9a05-000000000019",
      "name": "Under Threshold",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [1320, 240]
    }
  ],

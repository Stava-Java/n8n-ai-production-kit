      "name": "Check Idempotency Ledger",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [220, 0],
      "notes": "Select the imported PK-04 Idempotency Ledger workflow here after import (see INSTALL.md). This is what makes repeated runs safe: same day + provider never logs cost twice."
    },
    {
      "parameters": {
        "conditions": {
          "options": {

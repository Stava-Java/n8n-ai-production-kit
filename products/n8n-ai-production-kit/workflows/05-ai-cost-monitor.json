              "triggerAtHour": 6,
              "triggerAtMinute": 0
            }
          ]
        }
      },
      "id": "9f1a2b30-0005-4c05-9a05-000000000001",
      "name": "Run Daily",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [-1320, 0]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "set-threshold",
              "name": "daily_spend_alert_usd",
              "value": 25,
              "type": "number"

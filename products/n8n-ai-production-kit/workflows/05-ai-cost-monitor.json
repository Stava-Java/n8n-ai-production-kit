      "typeVersion": 2.2,
      "position": [440, 0]
    },
    {
      "parameters": {},
      "id": "9f1a2b30-0005-4c05-9a05-000000000014",
      "name": "Skip Duplicate",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [660, -140],
      "notes": "Already recorded for this provider and day. Re-running the workflow is safe."

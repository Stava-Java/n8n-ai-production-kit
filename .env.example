# Only needed for optional Docker self-hosting (INSTALL.md Appendix A).
# Copy to .env next to docker-compose.yml. n8n Cloud users can ignore this file.
#
# All kit configuration (Slack channels, thresholds, GitHub repo, etc.) is
# typed directly into the Settings nodes on each workflow canvas - there are
# no kit environment variables anymore.

GENERIC_TIMEZONE=America/New_York
